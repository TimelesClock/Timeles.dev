---
import "@/styles/globals.css";
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";

const allPosts = await getCollection("post");
const sortedPosts = allPosts.sort((a, b) => {
  return (
    new Date(b.data.timestamp).getTime() - new Date(a.data.timestamp).getTime()
  );
});
---

<Layout title="Andy Leong | Posts">
  <div class="page">
    <a href="/" class="back-link">← Home</a>

    <header class="page-header">
      <span class="sec-label">Writing</span>
      <h1 class="page-title">All Posts</h1>
    </header>

    <div class="rule"></div>

    <div class="card-grid">
      {
        sortedPosts.map((post) => {
          const { data: frontmatter, slug } = post;
          const { title, timestamp, description, images, tags } = frontmatter;
          return (
            <a href={`/posts/${slug}`} class="card">
              <div class="card-img-wrap">
                {images && images[0] ? (
                  <img
                    class="card-img"
                    src={images[0].src}
                    alt={images[0].alt ?? title}
                    loading="lazy"
                  />
                ) : (
                  <div class="card-img-placeholder">
                    <span class="placeholder-text">No image</span>
                  </div>
                )}
              </div>

              <div class="card-body">
                <div class="pill-row">
                  {tags.map((t: string) => (
                    <span class="pill">{t}</span>
                  ))}
                </div>

                <h2 class="card-title">{title}</h2>
                <p class="card-desc">{description}</p>

                <div class="card-footer">
                  <time class="card-date">
                    {new Date(timestamp).toLocaleDateString("en-SG", {
                      year: "numeric",
                      month: "short",
                      day: "numeric",
                    })}
                  </time>
                  <span class="card-cta">Read →</span>
                </div>
              </div>
            </a>
          );
        })
      }
    </div>
  </div>
</Layout>

<style>
  .page {
    max-width: 70vw;
    margin: 0 auto;
    padding: 1rem 2rem 6rem;
  }

  .back-link {
    display: inline-block;
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    color: hsl(215, 20%, 36%);
    text-decoration: none;
    margin-bottom: 2.5rem;
    transition: color 0.2s;
  }
  .back-link:hover {
    color: hsl(210, 40%, 65%);
  }

  .page-header {
    margin-bottom: 2rem;
  }

  .sec-label {
    display: block;
    font-size: 0.65rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: hsl(215, 20%, 38%);
    margin-bottom: 0.4rem;
  }

  .page-title {
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    font-weight: 700;
    letter-spacing: -0.025em;
    color: hsl(210, 40%, 93%);
    line-height: 1.15;
    margin: 0;
  }

  .rule {
    height: 1px;
    background: hsl(217, 33%, 10%);
    margin-bottom: 2.5rem;
  }

  /* Grid — flex-wrap so partial rows auto-center */
  .card-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1.25rem;
  }

  /* Card fixed width so 3-up fills naturally, 1-2 center */
  .card {
    flex: 0 0 calc(33.333% - 0.84rem);
    min-width: 220px;
    display: flex;
    flex-direction: column;
    background: hsl(222, 84%, 4%);
    text-decoration: none;
    transition:
      background 0.2s,
      border-color 0.2s;
    border: 1px solid hsl(217, 33%, 10%);
    border-radius: 8px;
    overflow: hidden;
  }
  .card:hover {
    background: hsl(222, 60%, 6%);
    border-color: hsl(217, 33%, 18%);
  }

  @media (max-width: 720px) {
    .page {
      max-width: 92vw;
      padding: 1rem 1rem 6rem;
    }
    .card {
      flex: 0 0 calc(50% - 0.625rem);
    }
  }
  @media (max-width: 480px) {
    .page {
      max-width: 96vw;
      padding: 1rem 0.75rem 6rem;
    }
    .card {
      flex: 0 0 100%;
    }
  }

  /* Image */
  .card-img-wrap {
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: hsl(217, 33%, 8%);
  }
  .card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }
  .card:hover .card-img {
    transform: scale(1.04);
  }
  .card-img-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .placeholder-text {
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: hsl(215, 20%, 24%);
  }

  /* Body */
  .card-body {
    display: flex;
    flex-direction: column;
    flex: 1;
    padding: 1.25rem 1.4rem 1.4rem;
    gap: 0.6rem;
  }

  .pill-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }
  .pill {
    font-size: 0.55rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.2rem 0.5rem;
    border-radius: 3px;
    background: hsl(217, 33%, 8%);
    color: hsl(215, 20%, 40%);
    border: 1px solid hsl(217, 33%, 14%);
  }

  .card-title {
    font-size: 0.96rem;
    font-weight: 600;
    color: hsl(210, 40%, 88%);
    line-height: 1.4;
    margin: 0;
  }

  .card-desc {
    font-size: 0.78rem;
    color: hsl(215, 20%, 44%);
    line-height: 1.65;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    flex: 1;
  }

  .card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: auto;
    padding-top: 0.75rem;
    border-top: 1px solid hsl(217, 33%, 9%);
  }

  .card-date {
    font-size: 0.63rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: hsl(215, 20%, 30%);
  }

  .card-cta {
    font-size: 0.7rem;
    letter-spacing: 0.06em;
    color: hsl(215, 20%, 34%);
    transition: color 0.2s;
  }
  .card:hover .card-cta {
    color: hsl(210, 40%, 65%);
  }
</style>
