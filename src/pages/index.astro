---
import "../styles/globals.css";
import Layout from "../layouts/Layout.astro";
import { ExternalLinkIcon } from "@radix-ui/react-icons";
import HeroCanvas from "@/components/HeroCanvas";
import { getCollection } from "astro:content";

let recent_projects = await getCollection("project");
recent_projects = recent_projects
  .sort(
    (a, b) =>
      new Date(b.data.timestamp).getTime() -
      new Date(a.data.timestamp).getTime(),
  )
  .slice(0, 5);

let recent_posts = await getCollection("post");
recent_posts = recent_posts
  .sort(
    (a, b) =>
      new Date(b.data.timestamp).getTime() -
      new Date(a.data.timestamp).getTime(),
  )
  .slice(0, 2);
---

<Layout title="Andy Leong">
  <!-- ── Hero ─────────────────────────────────────────────── -->
  <section class="hero-section">
    <div class="hero-canvas-wrapper">
      <HeroCanvas client:only="react" />
    </div>
    <div class="hero-vignette"></div>
    <div class="hero-content">
      <div class="hero-eyebrow">Singapore · Full-Stack Developer</div>
      <h1 class="hero-title">Andy Leong</h1>
      <p class="hero-subtitle">
        Computer Science enthusiast &amp; web designer hobbyist
      </p>
      <div class="hero-actions">
        <a href="/CV.pdf" target="_blank" class="btn-primary">View CV</a>
        <a href="/projects" class="btn-ghost">See projects →</a>
      </div>
    </div>
    <div class="scroll-hint">
      <span class="scroll-line"></span>
    </div>
  </section>

  <!-- ── Content ──────────────────────────────────────────── -->
  <div class="content-wrapper">
    <!-- Latest Posts -->
    <section class="section">
      <div class="section-header">
        <div>
          <div class="section-label">Writing</div>
          <h2 class="section-title">Latest posts</h2>
        </div>
        <a href="/posts" class="see-all-link">All posts →</a>
      </div>
      <div class="posts-grid">
        {
          recent_posts.map((post) => (
            <a href={`/posts/${post.slug}`} class="post-card">
              <div class="post-card-date">
                {new Date(post.data.timestamp).toLocaleDateString("en-SG", {
                  year: "numeric",
                  month: "short",
                  day: "numeric",
                })}
              </div>
              <h3 class="post-card-title">{post.data.title}</h3>
              <p class="post-card-desc">{post.data.description}</p>
              <div class="post-card-tags">
                {post.data.tags.map((tag: string) => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
            </a>
          ))
        }
      </div>
    </section>

    <div class="divider"></div>

    <!-- Recent Projects -->
    <section class="section">
      <div class="section-header">
        <div>
          <div class="section-label">Work</div>
          <h2 class="section-title">Recent Projects</h2>
        </div>
        <a href="/projects" class="see-all-link">All projects →</a>
      </div>
      <div class="projects-list">
        {
          recent_projects.map((project, index) => {
            const currentYear = new Date(project.data.timestamp).getFullYear();
            const prevProject = recent_projects[index - 1];
            const prevYear = prevProject
              ? new Date(prevProject.data.timestamp).getFullYear()
              : null;
            const showYear = index === 0 || currentYear !== prevYear;
            return (
              <div class="project-row-wrapper">
                {showYear && <div class="year-marker">{currentYear}</div>}
                <a
                  href={`/projects/${project.slug}`}
                  class="project-row"
                >
                  <div class="project-row-left">
                    <div class="project-row-dot" />
                    <div>
                      <div class="project-row-title">
                        {project.data.title}
                        <ExternalLinkIcon className="project-ext-icon" />
                      </div>
                      <div class="project-row-desc">
                        {project.data.description}
                      </div>
                    </div>
                  </div>
                  <div class="project-row-tags">
                    {project.data.tags.slice(0, 3).map((tag: string) => (
                      <span class="tag">{tag}</span>
                    ))}
                    {project.data.tags.length > 3 && (
                      <span class="tag-more">
                        +{project.data.tags.length - 3}
                      </span>
                    )}
                  </div>
                </a>
              </div>
            );
          })
        }
      </div>
    </section>

    <div class="divider"></div>

    <!-- Contact -->
    <section class="section contact-section">
      <div class="section-label" style="text-align:center">Get in touch</div>
      <h2 class="section-title" style="text-align:center;margin-bottom:0.6rem">
        Connect with me
      </h2>
      <p class="contact-sub">Have a project in mind or just want to say hi?</p>
      <a href="mailto:leongandy026@gmail.com" class="btn-primary contact-btn">
        leongandy026@gmail.com
      </a>
      <div class="social-row">
        <a
          href="https://github.com/timelesclock"
          target="_blank"
          rel="noreferrer"
          class="social-link"
          aria-label="GitHub"
        >
          <img src="/images/github-icon.svg" alt="GitHub" class="social-icon" />
        </a>
        <a
          href="https://www.linkedin.com/in/andy-leong-9bb486272/"
          target="_blank"
          rel="noreferrer"
          class="social-link"
          aria-label="LinkedIn"
        >
          <img
            src="/images/linkedin-icon.svg"
            alt="LinkedIn"
            class="social-icon"
          />
        </a>
      </div>
    </section>
  </div>
</Layout>

<style>
  /* ──────────────────────────────────────────────────────────
     Hero
  ────────────────────────────────────────────────────────── */
  .hero-section {
    position: relative;
    height: 100svh;
    min-height: 620px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .hero-canvas-wrapper {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  /* Radial vignette so particles fade at edges, text stays readable */
  .hero-vignette {
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      radial-gradient(
        ellipse 65% 55% at 50% 50%,
        transparent 15%,
        hsl(222, 84%, 4%) 75%
      ),
      linear-gradient(to bottom, transparent 50%, hsl(222, 84%, 4%) 100%);
  }

  .hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
    padding: 0 2rem;
    animation: fadeUp 0.9s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(28px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .hero-eyebrow {
    font-size: 0.8rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: hsl(215, 20%, 52%);
    margin-bottom: 1.4rem;
    animation: fadeUp 0.9s 0.1s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  .hero-title {
    /* clamp: min 3rem, fluid, max 6rem — visually large on 2K */
    font-size: clamp(3rem, 7vw, 6rem);
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -0.025em;
    color: hsl(210, 40%, 97%);
    margin-bottom: 1.1rem;
    animation: fadeUp 0.9s 0.15s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  .hero-subtitle {
    font-size: clamp(0.95rem, 1.6vw, 1.15rem);
    color: hsl(215, 20%, 52%);
    margin-bottom: 2.8rem;
    animation: fadeUp 0.9s 0.2s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  .hero-actions {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.1rem;
    flex-wrap: wrap;
    animation: fadeUp 0.9s 0.28s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  /* ── Buttons ── */
  .btn-primary {
    display: inline-flex;
    align-items: center;
    padding: 0.75rem 1.75rem;
    background: hsl(210, 40%, 96%);
    color: hsl(222, 84%, 8%);
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-decoration: none;
    border-radius: 5px;
    transition:
      opacity 0.2s,
      transform 0.2s;
  }
  .btn-primary:hover {
    opacity: 0.85;
    transform: translateY(-2px);
  }

  .btn-ghost {
    display: inline-flex;
    align-items: center;
    padding: 0.75rem 1.1rem;
    color: hsl(215, 20%, 60%);
    font-size: 0.85rem;
    text-decoration: none;
    border-radius: 5px;
    transition: color 0.2s;
  }
  .btn-ghost:hover {
    color: hsl(210, 40%, 96%);
  }

  /* Scroll indicator */
  .scroll-hint {
    position: absolute;
    bottom: 2.5rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    animation: fadeUp 1s 0.7s both;
  }
  .scroll-line {
    display: block;
    width: 1px;
    height: 3.5rem;
    background: linear-gradient(to bottom, transparent, hsl(215, 20%, 40%));
    animation: scrollPulse 2.2s ease-in-out infinite;
  }
  @keyframes scrollPulse {
    0%,
    100% {
      opacity: 0.25;
      transform: scaleY(0.75);
    }
    50% {
      opacity: 0.75;
      transform: scaleY(1);
    }
  }

  /* ──────────────────────────────────────────────────────────
     Layout — wider at 2K, uses vw for natural scaling
  ────────────────────────────────────────────────────────── */
  .content-wrapper {
    /* 
      min(1100px, 80vw) keeps a comfortable reading width
      at 2560px × 150% = effective 1707px logical — 80vw = ~1365px 
    */
    max-width: min(1100px, 80vw);
    margin: 0 auto;
    padding: 0 2rem;
  }

  .section {
    padding: 5.5rem 0;
  }

  .section-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: 2.8rem;
  }

  .section-label {
    font-size: 0.72rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: hsl(215, 20%, 42%);
    margin-bottom: 0.45rem;
  }

  .section-title {
    font-size: clamp(1.5rem, 2.5vw, 2rem);
    font-weight: 700;
    color: hsl(210, 40%, 94%);
    letter-spacing: -0.015em;
    line-height: 1.2;
  }

  .see-all-link {
    font-size: 0.82rem;
    color: hsl(215, 20%, 48%);
    text-decoration: none;
    letter-spacing: 0.04em;
    padding-bottom: 0.2rem;
    transition: color 0.2s;
    white-space: nowrap;
  }
  .see-all-link:hover {
    color: hsl(210, 40%, 92%);
  }

  .divider {
    height: 1px;
    background: hsl(217, 33%, 13%);
  }

  /* ──────────────────────────────────────────────────────────
     Posts
  ────────────────────────────────────────────────────────── */
  .posts-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: hsl(217, 33%, 13%);
    border: 1px solid hsl(217, 33%, 13%);
    border-radius: 10px;
    overflow: hidden;
  }
  @media (max-width: 640px) {
    .posts-grid {
      grid-template-columns: 1fr;
    }
  }

  .post-card {
    display: block;
    padding: 2rem;
    background: hsl(222, 84%, 4%);
    text-decoration: none;
    transition: background 0.2s;
  }
  .post-card:hover {
    background: hsl(222, 55%, 7%);
  }

  .post-card-date {
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    color: hsl(215, 20%, 38%);
    margin-bottom: 0.8rem;
    text-transform: uppercase;
  }

  .post-card-title {
    font-size: 1.05rem;
    font-weight: 600;
    color: hsl(210, 40%, 93%);
    line-height: 1.4;
    margin-bottom: 0.6rem;
  }

  .post-card-desc {
    font-size: 0.84rem;
    color: hsl(215, 20%, 50%);
    line-height: 1.65;
    margin-bottom: 1.1rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  /* ──────────────────────────────────────────────────────────
     Tags
  ────────────────────────────────────────────────────────── */
  .tag {
    font-size: 0.65rem;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    padding: 0.22rem 0.55rem;
    border-radius: 3px;
    background: hsl(217, 33%, 11%);
    color: hsl(215, 20%, 48%);
    border: 1px solid hsl(217, 33%, 17%);
  }
  .tag-more {
    font-size: 0.65rem;
    color: hsl(215, 20%, 38%);
    padding: 0.22rem 0.4rem;
    align-self: center;
  }

  /* ──────────────────────────────────────────────────────────
     Projects
  ────────────────────────────────────────────────────────── */
  .projects-list {
    display: flex;
    flex-direction: column;
  }

  .project-row-wrapper {
    position: relative;
  }

  .year-marker {
    font-size: 0.7rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: hsl(215, 20%, 32%);
    padding: 1.8rem 0 0.85rem;
  }

  .project-row {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 1.4rem 1.1rem;
    margin: 0 -1.1rem;
    border-radius: 7px;
    text-decoration: none;
    border-bottom: 1px solid hsl(217, 33%, 10%);
    transition: background 0.15s;
  }
  .project-row:hover {
    background: hsl(222, 55%, 7%);
  }
  .project-row:last-child {
    border-bottom: none;
  }

  .project-row-left {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    flex: 1;
    min-width: 0;
  }

  .project-row-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: hsl(215, 20%, 32%);
    flex-shrink: 0;
    margin-top: 0.5rem;
    transition: background 0.15s;
  }
  .project-row:hover .project-row-dot {
    background: hsl(210, 40%, 78%);
  }

  .project-row-title {
    font-size: 0.96rem;
    font-weight: 600;
    color: hsl(210, 40%, 90%);
    margin-bottom: 0.35rem;
    display: flex;
    align-items: center;
    gap: 0.45rem;
  }

  :global(.project-ext-icon) {
    width: 13px;
    height: 13px;
    color: hsl(215, 20%, 42%);
    flex-shrink: 0;
  }

  .project-row-desc {
    font-size: 0.82rem;
    color: hsl(215, 20%, 46%);
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .project-row-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.38rem;
    justify-content: flex-end;
    flex-shrink: 0;
    max-width: 220px;
    align-self: center;
  }
  @media (max-width: 640px) {
    .project-row {
      flex-direction: column;
    }
    .project-row-tags {
      max-width: none;
      justify-content: flex-start;
    }
  }

  /* ──────────────────────────────────────────────────────────
     Contact
  ────────────────────────────────────────────────────────── */
  .contact-section {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding-bottom: 7rem;
  }

  .contact-sub {
    font-size: 0.88rem;
    color: hsl(215, 20%, 46%);
    margin-bottom: 2.2rem;
  }

  .contact-btn {
    font-size: 0.82rem;
    margin-bottom: 2.2rem;
  }

  .social-row {
    display: flex;
    gap: 1.5rem;
  }

  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.55rem;
    border-radius: 7px;
    transition: background 0.2s;
  }
  .social-link:hover {
    background: hsl(217, 33%, 13%);
  }

  .social-icon {
    width: 1.35rem;
    height: 1.35rem;
    filter: invert(100%) sepia(0%) saturate(0%) brightness(65%) contrast(100%);
    transition: filter 0.2s;
  }
  .social-link:hover .social-icon {
    filter: invert(100%) sepia(0%) saturate(0%) brightness(100%) contrast(100%);
  }
</style>
