---
import "../styles/globals.css";
import Layout from "../layouts/Layout.astro";
import { ExternalLinkIcon } from "@radix-ui/react-icons";
import FallingCubes2D from "@/components/Cubes";
import { getCollection } from "astro:content";

let recent_projects = await getCollection("project");
recent_projects = recent_projects
  .sort(
    (a, b) =>
      new Date(b.data.timestamp).getTime() -
      new Date(a.data.timestamp).getTime(),
  )
  .slice(0, 5);

let recent_posts = await getCollection("post");
recent_posts = recent_posts
  .sort(
    (a, b) =>
      new Date(b.data.timestamp).getTime() -
      new Date(a.data.timestamp).getTime(),
  )
  .slice(0, 2);
---

<Layout title="Andy Leong">
  <!-- ═══════════════════ HERO ════════════════════════════ -->
  <section class="hero">
    <div class="hero-bg">
      <FallingCubes2D client:only="react" />
    </div>
    <div class="hero-fade"></div>

    <div class="hero-copy">
      <p class="eyebrow">Singapore · Full-Stack Developer</p>
      <h1 class="hero-name">Andy Leong</h1>
      <p class="hero-sub">
        Computer Science enthusiast &amp; web designer hobbyist
      </p>
      <div class="hero-ctas">
        <a href="/CV.pdf" target="_blank" class="btn-primary">View CV</a>
        <a href="/projects" class="btn-ghost">See projects →</a>
      </div>
    </div>

    <div class="scroll-cue" aria-hidden="true">
      <span class="scroll-bar"></span>
    </div>
  </section>

  <!-- ═══════════════════ CONTENT ═════════════════════════ -->
  <div class="page">
    <section class="sec">
      <header class="sec-head">
        <div>
          <span class="sec-label">Writing</span>
          <h2 class="sec-title">Latest posts</h2>
        </div>
        <a href="/posts" class="link-arrow">All posts →</a>
      </header>
      <div class="post-grid">
        {
          recent_posts.map((post) => (
            <a href={`/posts/${post.slug}`} class="post-card">
              <time class="card-date">
                {new Date(post.data.timestamp).toLocaleDateString("en-SG", {
                  year: "numeric",
                  month: "short",
                  day: "numeric",
                })}
              </time>
              <h3 class="card-title">{post.data.title}</h3>
              <p class="card-body">{post.data.description}</p>
              <div class="pill-row">
                {post.data.tags.map((t: string) => (
                  <span class="pill">{t}</span>
                ))}
              </div>
            </a>
          ))
        }
      </div>
    </section>

    <div class="rule"></div>

    <section class="sec">
      <header class="sec-head">
        <div>
          <span class="sec-label">Work</span>
          <h2 class="sec-title">Recent Projects</h2>
        </div>
        <a href="/projects" class="link-arrow">All projects →</a>
      </header>
      <div class="proj-list">
        {
          recent_projects.map((project, i) => {
            const yr = new Date(project.data.timestamp).getFullYear();
            const prev = recent_projects[i - 1];
            const showYr =
              i === 0 || yr !== new Date(prev.data.timestamp).getFullYear();
            return (
              <div>
                {showYr && <div class="yr-label">{yr}</div>}
                <a href={`/projects/${project.slug}`} class="proj-row">
                  <div class="proj-left">
                    <span class="proj-dot" />
                    <div>
                      <div class="proj-name">
                        {project.data.title}
                        <ExternalLinkIcon className="proj-ext" />
                      </div>
                      <div class="proj-desc">{project.data.description}</div>
                    </div>
                  </div>
                  <div class="pill-row pill-row--end">
                    {project.data.tags.slice(0, 3).map((t: string) => (
                      <span class="pill">{t}</span>
                    ))}
                    {project.data.tags.length > 3 && (
                      <span class="pill pill--dim">
                        +{project.data.tags.length - 3}
                      </span>
                    )}
                  </div>
                </a>
              </div>
            );
          })
        }
      </div>
    </section>

    <div class="rule"></div>

    <section class="sec contact-sec">
      <p class="eyebrow" style="text-align:center">Get in touch</p>
      <h2 class="contact-title">Let's work together</h2>
      <p class="contact-copy">
        Open to collaborations, freelance projects, and interesting
        conversations.
      </p>
      <a href="mailto:leongandy026@gmail.com" class="btn-primary">
        leongandy026@gmail.com
      </a>
      <div class="social-row">
        <a
          href="https://github.com/timelesclock"
          target="_blank"
          rel="noreferrer"
          class="social-a"
          aria-label="GitHub"
        >
          <img src="/images/github-icon.svg" alt="" class="social-ico" />
        </a>
        <a
          href="https://www.linkedin.com/in/andy-leong-9bb486272/"
          target="_blank"
          rel="noreferrer"
          class="social-a"
          aria-label="LinkedIn"
        >
          <img src="/images/linkedin-icon.svg" alt="" class="social-ico" />
        </a>
      </div>
    </section>
  </div>
</Layout>

<style>
  /* ── Hero ─────────────────────────────────────────────────── */
  .hero {
    position: relative;
    height: 100svh;
    min-height: 620px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .hero-fade {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 200px;
    z-index: 1;
    background: linear-gradient(to bottom, transparent, hsl(222, 84%, 4%));
    pointer-events: none;
  }
  .hero-copy {
    position: relative;
    z-index: 2;
    text-align: center;
    padding: 0 2rem;
    animation: rise 1s cubic-bezier(0.22, 1, 0.36, 1) both;
  }
  @keyframes rise {
    from {
      opacity: 0;
      transform: translateY(24px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .eyebrow {
    font-size: 0.72rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: hsl(215, 20%, 48%);
    margin-bottom: 1.4rem;
    opacity: 0;
    animation: rise 1s 0.1s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }
  .hero-name {
    font-size: clamp(3.2rem, 8vw, 6.5rem);
    font-weight: 700;
    line-height: 1;
    letter-spacing: -0.03em;
    color: hsl(210, 40%, 96%);
    margin-bottom: 1.1rem;
    opacity: 0;
    animation: rise 1s 0.18s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }
  .hero-sub {
    font-size: clamp(0.88rem, 1.5vw, 1.05rem);
    color: hsl(215, 20%, 48%);
    line-height: 1.7;
    margin-bottom: 2.8rem;
    opacity: 0;
    animation: rise 1s 0.26s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }
  .hero-ctas {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.4rem;
    flex-wrap: wrap;
    opacity: 0;
    animation: rise 1s 0.34s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }
  .btn-primary {
    display: inline-flex;
    align-items: center;
    padding: 0.7rem 1.6rem;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    text-decoration: none;
    color: hsl(222, 60%, 7%);
    background: hsl(210, 35%, 92%);
    border-radius: 4px;
    transition:
      background 0.2s,
      box-shadow 0.2s;
  }
  .btn-primary:hover {
    background: hsl(210, 40%, 98%);
    box-shadow: 0 0 24px hsla(210, 40%, 80%, 0.2);
  }
  .btn-ghost {
    font-size: 0.78rem;
    letter-spacing: 0.06em;
    color: hsl(215, 20%, 42%);
    text-decoration: none;
    transition: color 0.2s;
  }
  .btn-ghost:hover {
    color: hsl(210, 40%, 75%);
  }

  .scroll-cue {
    position: absolute;
    bottom: 2.2rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 3;
    opacity: 0;
    animation: rise 1s 1s forwards;
  }
  .scroll-bar {
    display: block;
    width: 1px;
    height: 3rem;
    background: linear-gradient(to bottom, transparent, hsl(215, 20%, 38%));
    animation: breathe 2.5s ease-in-out infinite;
  }
  @keyframes breathe {
    0%,
    100% {
      opacity: 0.2;
      transform: scaleY(0.6) translateY(-6px);
    }
    50% {
      opacity: 0.7;
      transform: scaleY(1) translateY(0);
    }
  }

  /* ── Page content ─────────────────────────────────────────── */
.page {
  max-width: min(860px, 72vw);
  margin: 0 auto;
  padding: 1rem 2rem 6rem;
}

  .sec {
    padding: 5rem 0;
  }
  .sec-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: 2.5rem;
  }
  .sec-label {
    display: block;
    font-size: 0.65rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: hsl(215, 20%, 38%);
    margin-bottom: 0.4rem;
  }
  .sec-title {
    font-size: clamp(1.4rem, 2.5vw, 1.9rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: hsl(210, 40%, 92%);
    line-height: 1.15;
    margin: 0;
  }
  .link-arrow {
    font-size: 0.74rem;
    color: hsl(215, 20%, 36%);
    text-decoration: none;
    letter-spacing: 0.04em;
    white-space: nowrap;
    transition: color 0.2s;
  }
  .link-arrow:hover {
    color: hsl(210, 40%, 72%);
  }
  .rule {
    height: 1px;
    background: hsl(217, 33%, 10%);
  }

  /* Posts */
  .post-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }
  @media (max-width: 600px) {
    .post-grid {
      grid-template-columns: 1fr;
    }
  }
  .post-card {
    display: flex;
    flex-direction: column;
    padding: 1.8rem;
    background: hsl(222, 84%, 4%);
    text-decoration: none;
    border: 1px solid hsl(217, 33%, 10%);
    border-radius: 8px;
    transition:
      background 0.2s,
      border-color 0.2s;
  }
  .post-card:hover {
    background: hsl(222, 60%, 6%);
    border-color: hsl(217, 33%, 18%);
  }

  /* Pills */
  .pill-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }
  .pill-row--end {
    justify-content: flex-end;
    align-self: center;
    flex-shrink: 0;
    max-width: 210px;
  }
  .pill {
    font-size: 0.58rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.2rem 0.5rem;
    border-radius: 3px;
    background: hsl(217, 33%, 8%);
    color: hsl(215, 20%, 40%);
    border: 1px solid hsl(217, 33%, 13%);
  }
  .pill--dim {
    color: hsl(215, 20%, 28%);
    background: transparent;
    border-color: transparent;
  }

  /* Projects */
  .proj-list {
    display: flex;
    flex-direction: column;
  }
  .yr-label {
    font-size: 0.63rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: hsl(215, 20%, 26%);
    padding: 1.8rem 0 0.75rem;
  }
  .proj-row {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 1.3rem 1rem;
    margin: 0 -1rem;
    border-radius: 6px;
    text-decoration: none;
    border-bottom: 1px solid hsl(217, 33%, 8%);
    transition: background 0.15s;
  }
  .proj-row:hover {
    background: hsl(222, 60%, 6%);
  }
  .proj-row:last-child {
    border-bottom: none;
  }
  .proj-left {
    display: flex;
    align-items: flex-start;
    gap: 0.85rem;
    flex: 1;
    min-width: 0;
  }
  .proj-dot {
    display: block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: hsl(215, 20%, 26%);
    flex-shrink: 0;
    margin-top: 0.46rem;
    transition: background 0.2s;
  }
  .proj-row:hover .proj-dot {
    background: hsl(210, 40%, 65%);
  }
  .proj-name {
    font-size: 0.92rem;
    font-weight: 600;
    color: hsl(210, 40%, 86%);
    margin-bottom: 0.3rem;
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }
  :global(.proj-ext) {
    width: 12px;
    height: 12px;
    color: hsl(215, 20%, 34%);
    flex-shrink: 0;
    transition: color 0.2s;
  }
  .proj-row:hover :global(.proj-ext) {
    color: hsl(210, 40%, 60%);
  }
  .proj-desc {
    font-size: 0.78rem;
    color: hsl(215, 20%, 42%);
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  @media (max-width: 600px) {
    .proj-row {
      flex-direction: column;
    }
    .pill-row--end {
      max-width: none;
      justify-content: flex-start;
    }
  }

  /* Contact */
  .contact-sec {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-bottom: 7rem;
  }
  .contact-title {
    font-size: clamp(1.8rem, 3vw, 2.5rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: hsl(210, 40%, 92%);
    text-align: center;
    margin-bottom: 0.5rem;
  }
  .contact-copy {
    font-size: 0.84rem;
    color: hsl(215, 20%, 40%);
    margin-bottom: 2rem;
    text-align: center;
    line-height: 1.7;
  }
  .social-row {
    display: flex;
    gap: 0.8rem;
    margin-top: 2rem;
  }
  .social-a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 6px;
    border: 1px solid hsl(217, 33%, 12%);
    transition:
      border-color 0.2s,
      background 0.2s;
  }
  .social-a:hover {
    border-color: hsl(217, 33%, 20%);
    background: hsl(217, 33%, 8%);
  }
  .social-ico {
    width: 1rem;
    height: 1rem;
    filter: invert(100%) sepia(0%) saturate(0%) brightness(45%) contrast(100%);
    transition: filter 0.2s;
  }
  .social-a:hover .social-ico {
    filter: invert(100%) sepia(0%) saturate(0%) brightness(75%) contrast(100%);
  }
</style>
