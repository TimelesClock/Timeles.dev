---
import "@/styles/globals.css";
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import { ImageDialog } from "@/components/ImageDialog";
import { Button } from "@/components/ui/button";

export const prerender = true;

export async function getStaticPaths() {
  const entries = await getCollection("post");
  return entries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
---

<Layout title={`Andy Leong | ${entry.data.title}`}>
  <div class="page">
    <!-- Back -->
    <a href="/posts" class="back-link">← All posts</a>

    <!-- Header -->
    <header class="post-header">
      <div class="pill-row">
        {entry.data.tags.map((t: string) => <span class="pill">{t}</span>)}
      </div>
      <h1 class="post-title">{entry.data.title}</h1>
      <time class="post-date">
        {
          new Date(entry.data.timestamp).toLocaleDateString("en-SG", {
            year: "numeric",
            month: "long",
            day: "numeric",
          })
        }
      </time>
    </header>

    <div class="rule"></div>

    <!-- Images -->
    {
      entry.data.images && entry.data.images.length > 0 && (
        <div class="img-block">
          <ImageDialog
            title={entry.data.title}
            images={entry.data.images}
            client:load
          />
        </div>
      )
    }

    <!-- Content -->
    <article class="prose action-row">
      {entry.body}
    </article>

    <!-- Action links -->
    {
      (entry.data.demoLink || entry.data.codeLink) && (
        <div class="action-row">
          {entry.data.demoLink && (
            <a
              href={entry.data.demoLink}
              target="_blank"
              rel="noopener noreferrer"
              class="btn-solid"
            >
              View Demo
            </a>
          )}
          {entry.data.codeLink && (
            <a
              href={entry.data.codeLink}
              target="_blank"
              rel="noopener noreferrer"
              class="btn-outline"
            >
              <img src="/images/github-icon.svg" alt="" class="github-icon" />
              View Code
            </a>
          )}
        </div>
      )
    }

    <!-- Footer nav -->
    <div class="post-footer">
      <a href="/posts" class="back-link">← All posts</a>
    </div>
  </div>
</Layout>

<style>
  .page {
    max-width: min(640px, 72vw);
    margin: 0 auto;
    padding: 1rem 2rem 6rem;
  }

  /* Back link */
  .back-link {
    display: inline-block;
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    color: hsl(215, 20%, 36%);
    text-decoration: none;
    margin-bottom: 2.5rem;
    transition: color 0.2s;
  }
  .back-link:hover {
    color: hsl(210, 40%, 65%);
  }

  /* Header */
  .post-header {
    margin-bottom: 2rem;
  }

  .pill-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-bottom: 1.1rem;
  }
  .pill {
    font-size: 0.58rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.2rem 0.5rem;
    border-radius: 3px;
    background: hsl(217, 33%, 8%);
    color: hsl(215, 20%, 40%);
    border: 1px solid hsl(217, 33%, 14%);
  }

  .post-title {
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    font-weight: 700;
    letter-spacing: -0.025em;
    color: hsl(210, 40%, 93%);
    line-height: 1.15;
    margin-bottom: 0.75rem;
  }

  .post-date {
    display: block;
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: hsl(215, 20%, 34%);
  }

  .rule {
    height: 1px;
    background: hsl(217, 33%, 10%);
    margin-bottom: 2.5rem;
  }

  /* Images */
  .img-block {
    margin-bottom: 2.5rem;
  }

  /* Action buttons */
  .action-row {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 1.5rem;
  }
  .btn-solid {
    display: inline-flex;
    align-items: center;
    padding: 0.55rem 1.2rem;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    text-decoration: none;
    background: hsl(210, 35%, 92%);
    color: hsl(222, 60%, 7%);
    border-radius: 4px;
    transition: background 0.2s;
  }
  .btn-solid:hover {
    background: hsl(210, 40%, 98%);
  }

  .btn-outline {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.55rem 1.2rem;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    text-decoration: none;
    background: transparent;
    color: hsl(215, 20%, 50%);
    border: 1px solid hsl(217, 33%, 14%);
    border-radius: 4px;
    transition:
      border-color 0.2s,
      color 0.2s;
  }
  .btn-outline:hover {
    border-color: hsl(217, 33%, 24%);
    color: hsl(210, 40%, 72%);
  }

  .github-icon {
    width: 14px;
    height: 14px;
    filter: invert(100%) sepia(0%) saturate(0%) brightness(55%) contrast(100%);
  }

  /* Prose */
  .prose {
    font-size: 0.92rem;
    line-height: 1.8;
    color: hsl(215, 20%, 62%);
  }
  .prose :global(h1),
  .prose :global(h2),
  .prose :global(h3),
  .prose :global(h4) {
    font-weight: 700;
    letter-spacing: -0.015em;
    color: hsl(210, 40%, 88%);
    margin: 2rem 0 0.75rem;
    line-height: 1.25;
  }
  .prose :global(h1) {
    font-size: 1.5rem;
  }
  .prose :global(h2) {
    font-size: 1.25rem;
  }
  .prose :global(h3) {
    font-size: 1.1rem;
  }
  .prose :global(p) {
    margin-bottom: 1.3rem;
  }
  .prose :global(a) {
    color: hsl(210, 40%, 68%);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: hsl(215, 20%, 30%);
    transition:
      color 0.2s,
      text-decoration-color 0.2s;
  }
  .prose :global(a:hover) {
    color: hsl(210, 40%, 82%);
    text-decoration-color: hsl(210, 40%, 52%);
  }
  .prose :global(ul),
  .prose :global(ol) {
    padding-left: 1.4rem;
    margin-bottom: 1.3rem;
  }
  .prose :global(li) {
    margin-bottom: 0.4rem;
  }
  .prose :global(strong) {
    color: hsl(210, 40%, 82%);
    font-weight: 600;
  }
  .prose :global(code) {
    font-size: 0.84em;
    background: hsl(217, 33%, 10%);
    color: hsl(210, 40%, 78%);
    padding: 0.15em 0.4em;
    border-radius: 3px;
    border: 1px solid hsl(217, 33%, 15%);
  }
  .prose :global(pre) {
    background: hsl(217, 33%, 8%);
    border: 1px solid hsl(217, 33%, 13%);
    border-radius: 6px;
    padding: 1.25rem;
    overflow-x: auto;
    margin-bottom: 1.5rem;
  }
  .prose :global(pre code) {
    background: none;
    border: none;
    padding: 0;
    font-size: 0.85rem;
  }
  .prose :global(blockquote) {
    border-left: 3px solid hsl(217, 33%, 18%);
    padding-left: 1.25rem;
    color: hsl(215, 20%, 50%);
    margin: 1.5rem 0;
  }
  .prose :global(hr) {
    border: none;
    border-top: 1px solid hsl(217, 33%, 10%);
    margin: 2rem 0;
  }
  .prose :global(img) {
    max-width: 100%;
    border-radius: 6px;
    border: 1px solid hsl(217, 33%, 12%);
    margin: 1rem 0;
  }

  /* Footer */
  .post-footer {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid hsl(217, 33%, 10%);
  }
</style>
